<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =====================================================
         Module Category
         ===================================================== -->
    <record id="module_category_wasabi" model="ir.module.category">
        <field name="name">Wasabi Kitchen</field>
        <field name="description">Akses Sistem QR-Ordering &amp; KDS Wasabi Kitchen</field>
        <field name="sequence">25</field>
    </record>

    <!-- =====================================================
         Groups (Roles)
         Hierarki: Manager > Kasir / Koki (manager bisa semua)
         ===================================================== -->
    <record id="group_wasabi_koki" model="res.groups">
        <field name="name">Koki / Kitchen Staff</field>
        <field name="category_id" ref="module_category_wasabi"/>
        <field name="comment">Akses ke Kitchen Display System, koreksi stok manual, dan update status pesanan.</field>
    </record>

    <record id="group_wasabi_kasir" model="res.groups">
        <field name="name">Kasir / POS Operator</field>
        <field name="category_id" ref="module_category_wasabi"/>
        <field name="comment">Akses ke billing, konfirmasi pembayaran, dan riwayat transaksi hari ini.</field>
    </record>

    <record id="group_wasabi_manager" model="res.groups">
        <field name="name">Manager / Admin</field>
        <field name="category_id" ref="module_category_wasabi"/>
        <field name="implied_ids" eval="[(4, ref('group_wasabi_koki')), (4, ref('group_wasabi_kasir'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        <field name="comment">Akses penuh: master data menu, manajemen meja, laporan &amp; ekspor, pengaturan sistem.</field>
    </record>

    <!-- =====================================================
         Record Rules
         ===================================================== -->

    <!-- Kasir hanya lihat transaksi yang ia proses sendiri (kecuali manager) -->
    <record id="rule_transaction_kasir_own" model="ir.rule">
        <field name="name">Kasir: hanya transaksi sendiri</field>
        <field name="model_id" ref="model_wasabi_transaction"/>
        <field name="domain_force">[('staff_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_wasabi_kasir'))]"/>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_transaction_manager_all" model="ir.rule">
        <field name="name">Manager: semua transaksi</field>
        <field name="model_id" ref="model_wasabi_transaction"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_wasabi_manager'))]"/>
    </record>

</odoo>
