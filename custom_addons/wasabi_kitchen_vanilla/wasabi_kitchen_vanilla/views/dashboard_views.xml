<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =====================================================
         DASHBOARD — KPI Overview (TransientModel)
         ===================================================== -->
    <record id="view_wasabi_dashboard_form" model="ir.ui.view">
        <field name="name">wasabi.dashboard.form</field>
        <field name="model">wasabi.dashboard</field>
        <field name="arch" type="xml">
            <form string="Dashboard" create="false" edit="false" class="o_wasabi_dashboard">
                <sheet>
                    <div class="oe_title">
                        <h1>Dashboard Wasabi Kitchen</h1>
                        <p class="text-muted">Ringkasan operasional &amp; performa restoran.</p>
                    </div>

                    <group string="Hari Ini">
                        <group>
                            <field name="today_revenue" widget="monetary"/>
                            <field name="today_count"/>
                            <field name="today_avg" widget="monetary"/>
                        </group>
                        <group>
                            <field name="active_orders"/>
                            <field name="pending_orders"/>
                            <field name="cooking_orders"/>
                            <field name="ready_orders"/>
                        </group>
                    </group>

                    <group string="Periode Lebih Panjang">
                        <group>
                            <field name="week_revenue" widget="monetary"/>
                            <field name="week_count"/>
                        </group>
                        <group>
                            <field name="month_revenue" widget="monetary"/>
                            <field name="month_count"/>
                        </group>
                    </group>

                    <group string="Distribusi Pembayaran (Bulan Ini)">
                        <group>
                            <field name="cash_share" widget="percentage"/>
                            <field name="qris_share" widget="percentage"/>
                        </group>
                        <group>
                            <field name="tables_total"/>
                            <field name="tables_occupied"/>
                            <field name="low_stock_count"/>
                        </group>
                    </group>

                    <field name="currency_id" invisible="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Server action: bikin record baru tiap kali dibuka biar fresh.
         NOTE: pakai xml_id baru (action_wasabi_dashboard_open) karena
         action_wasabi_dashboard sebelumnya ter-register sebagai ir.actions.act_window
         dan Odoo menolak ganti model untuk external id yang sama. -->
    <record id="action_wasabi_dashboard_open" model="ir.actions.server">
        <field name="name">Dashboard</field>
        <field name="model_id" ref="model_wasabi_dashboard"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_dashboard()</field>
    </record>

</odoo>
