<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =====================================================
         KDS KANBAN — Antrian Masak (UC-06, UC-07)

         Kanban di-group by status dengan custom card style
         menampilkan elapsed time, urgency, items, & action buttons.
         ===================================================== -->
    <record id="view_wasabi_kds_kanban" model="ir.ui.view">
        <field name="name">wasabi.order.kds.kanban</field>
        <field name="model">wasabi.order</field>
        <field name="arch" type="xml">
            <kanban class="o_wasabi_kds_kanban" default_group_by="status"
                    records_draggable="false" group_create="false"
                    group_delete="false" sample="1">
                <field name="id"/>
                <field name="order_number"/>
                <field name="table_id"/>
                <field name="table_number"/>
                <field name="create_date"/>
                <field name="status"/>
                <field name="elapsed_minutes"/>
                <field name="urgency"/>
                <field name="item_count"/>
                <field name="total_qty"/>
                <field name="order_item_ids"/>
                <field name="notes"/>
                <progressbar field="urgency" colors='{"normal": "success", "warn": "warning", "late": "danger"}'/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click o_wasabi_kds_card o_urg_#{record.urgency.raw_value}">
                            <div class="o_wasabi_kds_head">
                                <div class="o_wasabi_kds_table">
                                    <strong>Meja <t t-esc="record.table_number.raw_value &lt; 10 ? '0' + record.table_number.raw_value : record.table_number.raw_value"/></strong>
                                    <small class="o_wasabi_kds_ord">#<field name="order_number"/></small>
                                </div>
                                <div t-attf-class="o_wasabi_kds_time o_urg_#{record.urgency.raw_value}">
                                    <i class="fa fa-clock-o"/>
                                    <t t-esc="((record.elapsed_minutes.raw_value || 0) + 0.5) | 0"/>m
                                </div>
                            </div>

                            <ul class="o_wasabi_kds_items">
                                <t t-foreach="record.order_item_ids.raw_value.slice(0,5)" t-as="line_id">
                                    <li>
                                        <span class="o_wasabi_kds_qty">×<t t-esc="record.order_item_ids.raw_value.length"/></span>
                                    </li>
                                </t>
                            </ul>

                            <div class="o_wasabi_kds_meta">
                                <span class="o_wasabi_chip"><field name="item_count"/> item</span>
                                <span class="o_wasabi_chip">qty <field name="total_qty"/></span>
                            </div>

                            <div class="o_wasabi_kds_actions">
                                <button name="action_start_cooking" type="object"
                                        class="btn btn-sm btn-primary o_wasabi_btn_start"
                                        invisible="status != 'pending'">
                                    ▶ Mulai Masak
                                </button>
                                <button name="action_mark_ready" type="object"
                                        class="btn btn-sm btn-success o_wasabi_btn_ready"
                                        invisible="status != 'cooking'">
                                    ✓ Ready
                                </button>
                                <span t-if="record.status.raw_value == 'ready'"
                                      class="badge o_wasabi_badge_ready">
                                    ✓ Siap diantar
                                </span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- =====================================================
         Form khusus KDS (rich detail untuk koki klik card)
         ===================================================== -->
    <record id="view_wasabi_kds_form" model="ir.ui.view">
        <field name="name">wasabi.order.kds.form</field>
        <field name="model">wasabi.order</field>
        <field name="priority">90</field>
        <field name="arch" type="xml">
            <form string="Detail Pesanan KDS" class="o_wasabi_kds_form">
                <header>
                    <button name="action_start_cooking" type="object"
                            string="▶ Mulai Masak" class="btn-primary"
                            invisible="status != 'pending'"/>
                    <button name="action_mark_ready" type="object"
                            string="✓ Tandai Ready" class="btn-success"
                            invisible="status != 'cooking'"/>
                    <button name="action_cancel" type="object"
                            string="Batalkan" class="btn-secondary"
                            invisible="status in ('paid','cancelled','ready')"
                            confirm="Yakin batalkan? Stok akan dikembalikan."/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="pending,cooking,ready"/>
                </header>
                <sheet>
                    <div class="o_wasabi_kds_form_head">
                        <div>
                            <div class="o_wasabi_label">Pesanan untuk</div>
                            <h1>Meja <field name="table_number" readonly="1" nolabel="1"/></h1>
                            <div class="o_wasabi_meta">
                                <field name="order_number" readonly="1" nolabel="1"/>
                                <span> · diterima </span>
                                <field name="create_date" readonly="1" nolabel="1"/>
                            </div>
                        </div>
                        <div t-attf-class="o_wasabi_clock o_urg_#{urgency}">
                            <field name="elapsed_minutes" readonly="1" nolabel="1"/> menit
                        </div>
                    </div>

                    <field name="order_item_ids" readonly="1">
                        <tree class="o_wasabi_kds_lines" create="false" delete="false" edit="false">
                            <field name="quantity" string="Qty"/>
                            <field name="name" string="Menu"/>
                            <field name="category_name" string="Kategori"/>
                            <field name="note" string="Catatan Khusus"/>
                        </tree>
                    </field>

                    <group string="Catatan Pesanan" invisible="not notes">
                        <field name="notes" readonly="1" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- =====================================================
         KDS Action — entry point untuk koki
         ===================================================== -->
    <record id="action_wasabi_kds" model="ir.actions.act_window">
        <field name="name">Antrian Masak (KDS)</field>
        <field name="res_model">wasabi.order</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('view_wasabi_kds_kanban')}),
            (0, 0, {'view_mode': 'tree',   'view_id': ref('view_wasabi_order_tree')}),
            (0, 0, {'view_mode': 'form',   'view_id': ref('view_wasabi_kds_form')})]"/>
        <field name="domain">[('status', 'in', ('pending','cooking','ready'))]</field>
        <field name="context">{'search_default_filter_today': 1}</field>
        <field name="search_view_id" ref="view_wasabi_order_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Tidak ada pesanan dalam antrian!</p>
            <p>Pesanan baru dari pelanggan akan muncul di sini secara otomatis.</p>
        </field>
    </record>

    <!-- =====================================================
         STOCK CORRECTION — Action khusus untuk koki (UC-08)
         Pakai view editable list dari menu_item
         ===================================================== -->
    <record id="action_wasabi_stock_correction" model="ir.actions.act_window">
        <field name="name">Koreksi Stok</field>
        <field name="res_model">wasabi.menu.item</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="context">{'search_default_group_category': 1}</field>
        <field name="search_view_id" ref="view_wasabi_menu_item_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Sesuaikan stok dengan kondisi fisik di dapur
            </p>
            <p>Klik pada angka stok untuk mengubahnya. Perubahan akan
               langsung tersinkron ke menu pelanggan.</p>
        </field>
    </record>

</odoo>
