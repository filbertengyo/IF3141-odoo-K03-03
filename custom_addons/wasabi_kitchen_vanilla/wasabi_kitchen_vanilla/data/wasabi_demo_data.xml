             KATEGORI MENU
             =========================================== -->
        <record id="category_sushi" model="wasabi.category">
            <field name="name">Sushi</field>
            <field name="icon">🍣</field>
            <field name="sequence">10</field>
            <field name="description">Sushi dan sashimi segar dari ikan pilihan.</field>
        </record>
        <record id="category_ramen" model="wasabi.category">
            <field name="name">Ramen</field>
            <field name="icon">🍜</field>
            <field name="sequence">20</field>
            <field name="description">Mie kuah khas Jepang dengan kaldu autentik.</field>
        </record>
        <record id="category_bento" model="wasabi.category">
            <field name="name">Bento</field>
            <field name="icon">🍱</field>
            <field name="sequence">30</field>
            <field name="description">Set menu lengkap dalam satu kotak.</field>
        </record>
        <record id="category_minuman" model="wasabi.category">
            <field name="name">Minuman</field>
            <field name="icon">🍵</field>
            <field name="sequence">40</field>
