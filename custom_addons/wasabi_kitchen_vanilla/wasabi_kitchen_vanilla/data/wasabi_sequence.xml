<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Sequence untuk Order: ORD-YYMM-NNNN -->
    <record id="seq_wasabi_order" model="ir.sequence">
        <field name="name">Wasabi Order</field>
        <field name="code">wasabi.order</field>
        <field name="prefix">ORD-%(y)s%(month)s-</field>
        <field name="padding">4</field>
        <field name="number_increment">1</field>
        <field name="use_date_range" eval="True"/>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Sequence untuk Transaksi: TRX-YYMM-NNNN -->
    <record id="seq_wasabi_transaction" model="ir.sequence">
        <field name="name">Wasabi Transaction</field>
        <field name="code">wasabi.transaction</field>
        <field name="prefix">TRX-%(y)s%(month)s-</field>
        <field name="padding">4</field>
        <field name="number_increment">1</field>
        <field name="use_date_range" eval="True"/>
        <field name="company_id" eval="False"/>
    </record>

</odoo>
