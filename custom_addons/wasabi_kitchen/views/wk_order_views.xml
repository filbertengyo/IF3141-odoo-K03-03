<?xml version="1.0" encoding="UTF-8"?>
<odoo>

  <!-- ═══ UC-04: LIST PESANAN AKTIF + UC-10: TRIGGER BILLING ═══ -->
  <record id="wk_view_order_tree" model="ir.ui.view">
    <field name="name">wk.pos.order.tree.ordering</field>
    <field name="model">pos.order</field>
    <field name="priority">16</field>
    <field name="arch" type="xml">
      <tree string="Daftar Pesanan"
            decoration-warning="kds_status == 'pending'"
            decoration-info="kds_status == 'cooking'"
            decoration-success="kds_status == 'ready'">
        <field name="name" string="No. Order"/>
        <field name="table_id" string="Meja"/>
        <field name="no_meja" string="No. Meja" optional="show"/>
        <field name="amount_total" string="Total" widget="monetary"/>
        <field name="kds_status" string="Status"
               widget="badge"
               options="{'color_map': {'pending': 'warning', 'cooking': 'info', 'ready': 'success'}}"/>
        <field name="date_order" string="Waktu"/>
        <field name="state" string="POS State" optional="hide" invisible="1"/>
        <button name="action_open_billing" type="object"
                string="Buka Billing" icon="fa-money"
                class="btn-sm btn-primary"
                invisible="kds_status != 'ready'"/>
      </tree>
    </field>
  </record>

  <record id="wk_view_order_tree_history" model="ir.ui.view">
    <field name="name">wk.pos.order.tree.history</field>
    <field name="model">pos.order</field>
    <field name="priority">16</field>
    <field name="arch" type="xml">
      <tree string="Riwayat Transaksi">
        <field name="name" string="No. Order"/>
        <field name="no_meja" string="No. Meja"/>
        <field name="table_id" string="Meja"/>
        <field name="amount_total" string="Total" widget="monetary"/>
        <field name="date_order" string="Waktu"/>
        <field name="state" string="Status"
               widget="badge"
               options="{'color_map': {'paid': 'success', 'done': 'success', 'invoiced': 'info'}}"/>
      </tree>
    </field>
  </record>

  <record id="wk_search_order" model="ir.ui.view">
    <field name="name">wk.pos.order.search.order</field>
    <field name="model">pos.order</field>
    <field name="priority">16</field>
    <field name="arch" type="xml">
      <search string="Cari Pesanan">
        <field name="name" string="No. Order"/>
        <field name="table_id" string="Meja"/>
        <filter name="f_today" string="Hari Ini"
                domain="[('date_order', '&gt;=',
                  datetime.datetime.combine(context_today(),
                  datetime.time(0, 0, 0)).strftime('%Y-%m-%d %H:%M:%S'))]"/>
        <filter name="f_pending" string="Pending"
                domain="[('kds_status', '=', 'pending')]"/>
        <filter name="f_cooking" string="Sedang Dimasak"
                domain="[('kds_status', '=', 'cooking')]"/>
        <filter name="f_ready" string="Siap Dibayar"
                domain="[('kds_status', '=', 'ready')]"/>
        <group expand="0" string="Kelompokkan">
          <filter name="g_meja" string="Meja"
                  context="{'group_by': 'table_id'}"/>
          <filter name="g_status" string="Status KDS"
                  context="{'group_by': 'kds_status'}"/>
          <filter name="g_date" string="Tanggal"
                  context="{'group_by': 'date_order:day'}"/>
        </group>
      </search>
    </field>
  </record>

  <record id="wk_action_order_aktif" model="ir.actions.act_window">
    <field name="name">Daftar Pesanan</field>
    <field name="res_model">pos.order</field>
    <field name="view_mode">tree,form</field>
    <field name="domain">[('state', '=', 'draft')]</field>
    <field name="context">{'search_default_f_today': 1}</field>
    <field name="view_ids" eval="[
      (5, 0, 0),
      (0, 0, {'view_mode': 'tree', 'view_id': ref('wk_view_order_tree')}),
    ]"/>
    <field name="search_view_id" ref="wk_search_order"/>
  </record>

  <record id="wk_action_order_history" model="ir.actions.act_window">
    <field name="name">Riwayat Transaksi</field>
    <field name="res_model">pos.order</field>
    <field name="view_mode">tree</field>
    <field name="domain">[('state', 'in', ['paid', 'done', 'invoiced'])]</field>
    <field name="context">{'search_default_f_today': 1}</field>
    <field name="view_ids" eval="[
      (5, 0, 0),
      (0, 0, {'view_mode': 'tree', 'view_id': ref('wk_view_order_tree_history')}),
    ]"/>
    <field name="search_view_id" ref="wk_search_order"/>
  </record>

</odoo>
