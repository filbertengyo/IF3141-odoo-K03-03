<?xml version="1.0" encoding="UTF-8"?>
<odoo>

  <!-- ═══ UC-06: KOREKSI STOK MANUAL ═══ -->
  <record id="wk_view_product_stock_tree" model="ir.ui.view">
    <field name="name">wk.product.template.stock.tree</field>
    <field name="model">product.template</field>
    <field name="priority">16</field>
    <field name="arch" type="xml">
      <tree string="Koreksi Stok"
            editable="bottom"
            decoration-danger="qty_available == 0"
            decoration-warning="qty_available &gt; 0 and qty_available &lt; 4"
            decoration-success="qty_available &gt;= 4">
        <field name="name" string="Nama Menu" readonly="1"/>
        <field name="categ_id" string="Kategori" readonly="1" optional="show"/>
        <field name="list_price" string="Harga (Rp)" readonly="1" widget="monetary"/>
        <field name="qty_available" string="Stok"/>
        <field name="uom_id" string="Satuan" readonly="1" optional="show"/>
      </tree>
    </field>
  </record>

  <record id="wk_search_stock" model="ir.ui.view">
    <field name="name">wk.product.template.search.stock</field>
    <field name="model">product.template</field>
    <field name="priority">16</field>
    <field name="arch" type="xml">
      <search string="Cari Menu">
        <field name="name" string="Nama Menu"/>
        <filter name="f_habis" string="Stok Habis"
                domain="[('qty_available', '=', 0)]"/>
        <filter name="f_menipis" string="Stok Menipis"
                domain="[('qty_available', '&gt;', 0), ('qty_available', '&lt;', 4)]"/>
        <filter name="f_aman" string="Stok Aman"
                domain="[('qty_available', '&gt;=', 4)]"/>
        <group expand="0" string="Kelompokkan">
          <filter name="g_cat" string="Kategori"
                  context="{'group_by': 'categ_id'}"/>
        </group>
      </search>
    </field>
  </record>

  <record id="wk_action_stock" model="ir.actions.act_window">
    <field name="name">Koreksi Stok</field>
    <field name="res_model">product.template</field>
    <field name="view_mode">tree,form</field>
    <field name="domain">[('available_in_pos', '=', True),
                          ('type', 'in', ['consu', 'product'])]</field>
    <field name="view_ids" eval="[
      (5, 0, 0),
      (0, 0, {'view_mode': 'tree', 'view_id': ref('wk_view_product_stock_tree')}),
    ]"/>
    <field name="search_view_id" ref="wk_search_stock"/>
  </record>

</odoo>
