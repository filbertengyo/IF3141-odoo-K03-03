  <menuitem id="wk_report_parent"  name="Pelaporan"         parent="wk_root" sequence="3"/>

  <!-- QR Ordering -->
  <menuitem id="wk_menu_daftar_pesanan" name="Daftar Pesanan"
            parent="wk_qr_parent" action="wk_action_order_aktif" sequence="1"/>
