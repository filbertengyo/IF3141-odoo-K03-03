            parent="wk_kds_parent" action="wk_action_kds" sequence="1"/>
  <menuitem id="wk_menu_stok" name="Koreksi Stok"
            parent="wk_kds_parent" action="wk_action_stock" sequence="2"/>

  <!-- Pelaporan -->
  <menuitem id="wk_menu_laporan" name="Laporan Transaksi"
            parent="wk_report_parent" action="wk_action_report_wizard" sequence="1"/>
